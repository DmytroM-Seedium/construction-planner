{
  "name": "@construction-planner/server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "npm run build -w @construction-planner/shared",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "echo \"No lint configured\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx src/tests/sync-service.test.ts"
  },
  "dependencies": {
    "@construction-planner/shared": "0.1.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.2.1",
    "@fastify/static": "^8.3.0",
    "fastify": "^5.6.1",
    "nanoid": "^5.1.5",
    "nedb": "^1.8.0"
  },
  "devDependencies": {
    "@types/nedb": "^1.8.16",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
